{
  "name": "creatorverse",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=22.12"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "start": "node server.js",
    "preview": "vite preview",
    "test": "node --test",
    "test:unit": "node --test test/*.test.js",
    "test:e2e": "playwright test",
    "test:a11y": "playwright test e2e/accessibility.spec.js",
    "test:i18n": "node scripts/check-i18n.mjs",
    "test:railway": "node --test test/railway-preview.test.js",
    "test:proxy-syntax": "node --check e2e/usability-proxy.spec.js && node --check scripts/usability-proxy-report.mjs",
    "check": "npm run test:proxy-syntax && npm run test:unit && npm run test:i18n && npm run build"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@playwright/test": "1.61.1",
    "vite": "7.3.6"
  }
}
